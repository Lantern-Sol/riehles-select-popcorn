<!doctype html>
<!--[if (gt IE 9)|!(IE)]><!--> <html class="no-js" lang="{{ shop.locale }}"> <!--<![endif]-->

<head>

  <!-- Blockshop Theme - Version 6.0.1 by Troop Themes - http://troopthemes.com/ -->

  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />

  {% if settings.favicon != blank %}
    <link rel="shortcut icon" href="{{ settings.favicon | img_url: '32x32' }}" type="image/png">
  {% endif %}

  {% if template == 'index' %}
    <title>{{ page_title }}</title>
  {% elsif template == 'password' %}
    <title>{{ shop.name }}</title>
  {% else %}
    <title>{{ page_title }} | {{ shop.name }}</title>
  {% endif %}

  {% if page_description %}
  <meta name="description" content="{{ page_description }}" />
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}" />

  {% include 'snippet-fb-open-graph-tags' %}

  {{ content_for_header }}
  {% comment %} Bold:POv2 {% endcomment %}
  {% include 'bold-hybrid' %}
  {%- include 'bold-product' with product, hide_action: 'header' -%}
  {%- include 'bold-common' -%}
{%- render 'sc-includes' -%}

  {% include 'framework--css-variables' %}
  {% include 'partial--css-variables' %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;800&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

  {{ "theme.scss.css" | asset_url | stylesheet_tag }}
  {{ 'theme--customizations.scss.css' | asset_url | stylesheet_tag }}

  <!-- >= IE 11 -->
  <style>
    @media screen and (-ms-high-contrast: active), (-ms-high-contrast: none) {
      .main-header .currency-selector select {
        width: 80px;
        padding-right: 10px;
      }
    }
  </style>

  <script type="text/javascript">
    window.lazySizesConfig = window.lazySizesConfig || {};
    window.lazySizesConfig.expand = 1200;
    window.lazySizesConfig.loadMode = 3;
    window.lazySizesConfig.ricTimeout = 50;
  </script>
  {{ 'lazysizes.min.js' | asset_url | script_tag }}

  {{ '//ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js' | script_tag }}
  {{ '//ajax.googleapis.com/ajax/libs/jqueryui/1.10.3/jquery-ui.min.js' | script_tag }}
  {{ 'api.jquery.js' | shopify_asset_url | script_tag }}
  {{ 'option_selection.js' | shopify_asset_url | script_tag }}

  {% if template contains 'customers' %}
    {{ 'shopify_common.js' | shopify_asset_url | script_tag }}
    {{ 'customer_area.js'  | shopify_asset_url | script_tag }}
  {% endif %}

  <script>
    var general_external_links_enabled = true,
    general_scroll_to_active_item = true,
    shop_url = '{{ shop.url }}',
    shop_money_format = '{{ shop.money_with_currency_format | escape }}',
    currency_switcher_enabled = {{ settings.show_multiple_currencies }},
    popup_config = {
      enabled               : {{ settings.popup--enabled }},
      test_mode             : {{ settings.popup--test-mode }},
      newsletter_enabled    : {{ settings.popup--newsletter--enabled }},
      social_icons_enabled  : {{ settings.popup--social-icons--enabled }},
      show_image_enabled    : '{{ settings.popup--image.size }}',
      image_link            : "{{ settings.popup--image-url }}",
      seconds_until         : {{ settings.popup--seconds-range }},

      {% comment %} So it doesnt get picked up by og:image {% endcomment %}
      {% if settings.popup--image %}
      show_image_url        : '{{ settings.popup--image | img_url: "1200x" | img_tag: settings.popup--image.alt | default: "" }}',
      {% endif %}

      page_content          : '{{ settings.popup--page-content }}',
      days_until            : '{{ settings.popup--days-range }}',
      storage_key           : 'troop_popup_storage'
    };

    popup_config.show_image_enabled = popup_config.show_image_enabled > 0 ?
                                      true :
                                      false;

    // newer naming convention
    var theme = {};
    theme.settings = {};
    theme.translation = {}; // refactor to pluralised
    theme.translations = {};
    theme.classes = {};
    theme.utils = {};
    theme.templates = {};
    theme.partials = {};
    theme.shop_currency = '{{ shop.currency | escape }}';

    theme.settings.currency_switcher_enabled = {{ settings.show_multiple_currencies }};
    theme.settings.cart_type = '{{ settings.cart--type }}';
    theme.translation.newsletter_email_blank = '{{ "layout.footer.newsletter_email_blank" | t }}';
    theme.translations.general_search_see_all_results = '{{ "general.search.see_all_results" | t }}';
    theme.translations.cart_item = '{{ "products.recently_added_popup.item" | t }}';
    theme.translations.cart_items = '{{ "products.recently_added_popup.items" | t }}';
    theme.preload_image = '{{ "popup.jpg" | asset_url }}';

    {% unless settings.show_multiple_currencies %}
      Shopify.money_format = "{{ shop.money_format | escape }}";
      Shopify.money_with_currency_format = "{{ shop.money_with_currency_format | escape }}";
    {% endunless %}

  </script>


  {% include 'snippet-currencies' %}

  {{ "theme.min.js" | asset_url | script_tag }}




<!-- BeginShopPopAddon --><script>  Shopify.shopPopSettings = {"proof_enabled":false,"proof_show_add_to_cart":true,"proof_mobile_enabled":true,"proof_mobile_position":"Bottom","proof_desktop_position":"Bottom Left","proof_show_on_product_page":true,"proof_hide_notification_after":30,"proof_display_time":6,"proof_interval_time":5,"proof_order_random":false,"proof_fetch_count":30,"proof_cycle":true,"proof_anonymize":true,"proof_anonymize_text":null,"proof_hours_before_obscure":48,"proof_sequential":true,"proof_top":10,"proof_left":10,"proof_right":10,"proof_bottom":10,"proof_background_color":"#FFFFFF","proof_font_color":"#000000","proof_custom_css":null,"proof_border_radius":40,"proof_first_interval_time":1,"proof_locale":"en"};</script><!-- EndShopPopAddon -->
</head>

<body class="page-{{ page_title | handle }} {% if customer %}customer-logged-in {% endif %}template-{{ template | split: '.' | first | remove: '/' | remove: '_' }}">

  {% include 'icon-sprite.svg' %}

  <div
    class="off-canvas--viewport"
    data-js-class="FrameworkOffCanvas"
    data-off-canvas--state="closed"
  >
    <div class="off-canvas--overlay"></div>
    <div class="off-canvas--close">{% include 'framework--icon', icon: 'cross' %}</div>

    <div class="off-canvas--left-sidebar">
      {% include 'partial--mobile-nav' %}
    </div>

    <div class="off-canvas--right-sidebar">
      {% include 'framework--cart', view: 'mobile' %}
    </div>

    <div class="off-canvas--main-content">
      {% section 'header' %}

      <section class="main-content">
        {{ content_for_layout }}
      </section>

      {% section 'footer' %}

      {% unless template == 'password' %}
        <div class="popup-modal-close">&#x2715;</div>
        <div class="popup-modal-mask"></div>
      {% endunless %}

      <!--<style> iframe#admin_bar_iframe { display: none !important; } </style>-->
    </div>

    {% include 'framework--feedback-bar' %}

    {% include 'partial--popup' %}

  </div>

  {% include 'framework--search', view: 'modal' %}

  <script>
    // Cart bubble: intercept AJAX cart calls and update count
    (function(){
      function updateBubbles(count) {
        document.querySelectorAll('.cart-icon-bubble').forEach(function(b){
          b.textContent = count;
          b.setAttribute('data-item-count', count);
        });
      }

      // Intercept XMLHttpRequest to catch /cart/add.js, /cart/change.js, /cart/update.js, /cart/clear.js
      var origOpen = XMLHttpRequest.prototype.open;
      var origSend = XMLHttpRequest.prototype.send;

      XMLHttpRequest.prototype.open = function(method, url) {
        this._cartUrl = (typeof url === 'string' && /\/cart\/(add|change|update|clear)\.js/i.test(url)) ? url : null;
        return origOpen.apply(this, arguments);
      };

      XMLHttpRequest.prototype.send = function() {
        if (this._cartUrl) {
          this.addEventListener('load', function() {
            // After any cart mutation, fetch fresh count
            fetch('/cart.js').then(function(r){ return r.json(); }).then(function(cart){
              updateBubbles(cart.item_count);
            }).catch(function(){});
          });
        }
        return origSend.apply(this, arguments);
      };

      // Also intercept fetch API
      var origFetch = window.fetch;
      window.fetch = function(url, opts) {
        var isCart = (typeof url === 'string' && /\/cart\/(add|change|update|clear)\.js/i.test(url));
        var promise = origFetch.apply(this, arguments);
        if (isCart) {
          promise.then(function(){
            return origFetch('/cart.js');
          }).then(function(r){ return r.json(); }).then(function(cart){
            updateBubbles(cart.item_count);
          }).catch(function(){});
        }
        return promise;
      };
    })();
  </script>
</body>
</html>
