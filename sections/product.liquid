        <span>Hulless Popcorn</span>
      </li>
      <li role="listitem">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M9 12V21M9 12L10.8462 7L15 5L19.1538 7L21 12V21H9M9 12V8M9 21H3V6C3 4.34315 4.34315 3 6 3C7.65685 3 9 4.34315 9 6V8M9 8H3M13 15H17V21H13V15ZM14.5 10V11H15.5V10H14.5Z"/></svg>
        <span>From Our Family Farm (Since 1910)</span>
      </li>
    </ul>
  </div>
</div>

{% if section.settings['product-share-this-show'] %}
  <section class="row social-share">
    <div class="columns">
      {% include 'snippet-product-share' with 'product-template' %}
    </div>
  </section>
{% endif %}

<script>
  // variables to pass to theme.js
  var product_title = '{{ product.title | escape }}';
  var product_variant_size = {{ product.variants.size }};
  var product_options_size = {{ product.options.size }};
  var product_options_size = 10;
  var product_options_first = '{{ product.options.first | escape }}';
  var product_json = {{ product | json }};
  var product_language_was = '{{ 'products.was' | t | escape }}';

  var selectCallback = function(variant, selector) {
    theme.partials.ProductPage.variantSelected(variant, selector);
    // After theme.js replaces .actual-price, re-apply data attributes and recalculate
    if (variant) {
      var $actualPrice = jQuery('.actual-price');
      $actualPrice.attr('data-unit-price', variant.price);
      if (variant.compare_at_price > variant.price) {
        jQuery('.compare-price').attr('data-unit-compare-price', variant.compare_at_price);
      } else {
        jQuery('.compare-price').removeAttr('data-unit-compare-price');
      }
      // Update sticky bar availability first so updateDisplayedPrice renders the correct state
      var stickyBtn = document.getElementById('sticky-add-btn');
      if (stickyBtn) {
        stickyBtn.disabled = !variant.available;
      }
      var qty = parseInt(jQuery('input[name="quantity"]').val()) || 1;
      updateDisplayedPrice(qty);
    }
  };

  theme.products = {
    size_chart: {
      label: '{{ "products.size_chart" | t }}'
    },
    low_in_stock: {
      one: '{{ "products.low_in_stock" | t: count: 1 }}',
      other: '{{ "products.low_in_stock" | t: count: 2 }}'
    }
  };

  document.addEventListener('DOMContentLoaded', function() {
    jQuery(function($) {
      function setOptionSelectors() {
        new Shopify.OptionSelectors("variant-listbox", {
          product: {{ product | json }},
          onVariantSelected: selectCallback,
          enableHistoryState: true
        });
      }

      setOptionSelectors();
    });
  });

  // --- Quantity-based pricing + Sticky Add-to-Cart ---
  var _moneyFmt = (typeof Shopify !== 'undefined' && Shopify.money_format) ? Shopify.money_format : {{ shop.money_format | json }};

  function getCurrentQty() {
    return parseInt(jQuery('input[name="quantity"]').val(), 10) || 1;
  }

  function updateDisplayedPrice(qty) {
    if (typeof qty === 'undefined') qty = getCurrentQty();
    var $actualPrice = jQuery('.actual-price');
    var unitPrice = parseInt($actualPrice.attr('data-unit-price'), 10);
    if (!unitPrice || unitPrice <= 0) return;

    var totalPrice = unitPrice * qty;
    var formattedPrice = (typeof Shopify !== 'undefined' && Shopify.formatMoney)
      ? Shopify.formatMoney(totalPrice, _moneyFmt)
      : '$' + (totalPrice / 100).toFixed(2);

    $actualPrice.html(formattedPrice);

    // Update sticky bar button — always rewrite full content since theme JS may overwrite it
    var $stickyBtn = jQuery('#sticky-add-btn');
    if ($stickyBtn.length) {
      if ($stickyBtn.prop('disabled')) {
        $stickyBtn.html({{ 'products.sold_out' | t | json }});
      } else {
        $stickyBtn.html({{ 'products.add_to_cart' | t | json }} + ' - <span class="actual-price-sticky money">' + formattedPrice + '</span>');
      }
    }

    // Update compare price if applicable
    var $comparePrice = jQuery('.compare-price');
    var unitCompare = parseInt($comparePrice.attr('data-unit-compare-price'), 10);
    if (unitCompare && unitCompare > unitPrice) {
      var totalCompare = unitCompare * qty;
      var formattedCompare = (typeof Shopify !== 'undefined' && Shopify.formatMoney)
        ? Shopify.formatMoney(totalCompare, _moneyFmt)
        : '$' + (totalCompare / 100).toFixed(2);
      $comparePrice.html('<span class="money font--light-accent">' + formattedCompare + '</span>');
    }

    // Re-run currency conversion if enabled
    if (typeof Currency !== 'undefined' && typeof shopCurrency !== 'undefined') {
      var selectedCurrency = jQuery('[name=currencies]').val();
      if (selectedCurrency && selectedCurrency !== shopCurrency) {
        Currency.convertAll(shopCurrency, selectedCurrency);
      }
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    jQuery(function($) {
      // Initialize sticky bar price on load
      var initialQty = getCurrentQty();
      updateDisplayedPrice(initialQty);

      // Listen for quantity changes (custom event from snippet-quantity)
      document.addEventListener('quantity:changed', function(e) {
        var qty = e.detail.quantity;
        updateDisplayedPrice(qty);
        // Sync to sticky bar qty input
        $('.sticky-qty-input').val(qty);
      });

      // Sticky bar quantity buttons
      $('.sticky-qty-minus').on('click', function() {
        var $input = $('.sticky-qty-input');
        var val = parseInt($input.val()) || 1;
        if (val > 1) {
          val--;
          $input.val(val);
          // Sync to main qty input and trigger update
          $('input[name="quantity"]').val(val).trigger('change');
        }
      });

      $('.sticky-qty-plus').on('click', function() {
        var $input = $('.sticky-qty-input');
        var val = parseInt($input.val()) || 1;
        val++;
        $input.val(val);
        $('input[name="quantity"]').val(val).trigger('change');
      });

      // Sticky bar qty input direct change
      $('.sticky-qty-input').on('change', function() {
        var val = parseInt($(this).val()) || 1;
        if (val < 1) val = 1;
        $(this).val(val);
        $('input[name="quantity"]').val(val).trigger('change');
      });

      // Sticky bar add-to-cart triggers main form submit
      $('#sticky-add-btn').on('click', function() {
        var $mainAddBtn = $('button[name="add"]#add');
        if ($mainAddBtn.length && !$(this).prop('disabled')) {
          $mainAddBtn.trigger('click');
        }
      });

      // IntersectionObserver to show/hide sticky bar
      var stickyBar = document.getElementById('sticky-atc-bar');
      var mainAddBtn = document.querySelector('button[name="add"]#add');

      if (stickyBar && mainAddBtn) {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              stickyBar.classList.remove('is-visible');
            } else {
              // Only show if product is available
              var addBtn = document.querySelector('button[name="add"]#add');
              if (addBtn && !addBtn.disabled) {
                stickyBar.classList.add('is-visible');
              }
            }
          });
        }, { threshold: 0 });

        observer.observe(mainAddBtn);
      }
    });
  });
</script>

{% if product.images.size > 1 %}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      jQuery(function ($) {
        var $root = $('.product-page--root');
        var $images = $root.find('.product-page--image');
        var $thumbs = $root.find('.product-page--thumb');
        var $zoomImages = $root.find('.product-page--zoom-image');

        function switchImage(direction) {
          var $active = $images.filter('[data-active="true"]');
          var currentIndex = $images.index($active);
          var nextIndex;

          if (direction === 'next') {
            nextIndex = (currentIndex + 1) % $images.length;
          } else {
            nextIndex = (currentIndex - 1 + $images.length) % $images.length;
          }

          var nextId = $images.eq(nextIndex).attr('data-id');

          // Hide all zoom images immediately
          $zoomImages.css('display', 'none');

          $images.attr('data-active', 'false');
          $images.eq(nextIndex).attr('data-active', 'true');

          $zoomImages.attr('data-active', 'false');
          $zoomImages.filter('[data-id="' + nextId + '"]').attr('data-active', 'true');

          $thumbs.attr('data-active', 'false');
          $thumbs.filter('[data-id="' + nextId + '"]').attr('data-active', 'true');

          // Re-initialize zoom for the new active image
          if (theme.partials.ProductPage && theme.partials.ProductPage.imageZoom) {
            theme.partials.ProductPage.imageZoom();
          }
        }

        $root.on('click', '.product-page--arrow-prev', function (e) {
          e.preventDefault();
          e.stopPropagation();
          switchImage('prev');
        });

        $root.on('click', '.product-page--arrow-next', function (e) {
          e.preventDefault();
          e.stopPropagation();
          switchImage('next');
        });
      });
    });
  </script>
{% endif %}

<div class="product-lightbox" id="product-lightbox">
  <div class="product-lightbox--overlay"></div>
  <div class="product-lightbox--content">
    <button type="button" class="product-lightbox--close" aria-label="Close">&times;</button>
    <img src="" alt="">
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    jQuery(function ($) {
      var $lightbox = $('#product-lightbox');
      var $img = $lightbox.find('img');
      var imageExts = /\.(jpg|jpeg|png|gif|webp)(\?|$)/i;

      $('.product-page--description .rte-content').on('click', 'a', function (e) {
        var href = $(this).attr('href');
        if (href && imageExts.test(href)) {
          e.preventDefault();
          $img.attr('src', href);
          $lightbox.addClass('active');
        }
      });

      $lightbox.on('click', '.product-lightbox--overlay, .product-lightbox--close', function () {
        $lightbox.removeClass('active');
        $img.attr('src', '');
      });

      $(document).on('keydown', function (e) {
        if (e.key === 'Escape' && $lightbox.hasClass('active')) {
          $lightbox.removeClass('active');
          $img.attr('src', '');
        }
      });
    });
  });
</script>

