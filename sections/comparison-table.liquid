    border-bottom: none;
  }

  .comparison-table tbody tr:last-child .comparison-table--td-hero {
    border-bottom: 2px solid #007494;
  }

  .comparison-table--td-feature {
    flex: 0 0 36%;
    flex-direction: column;
    align-items: flex-start !important;
    justify-content: center !important;
    padding: 15px 16px 15px 24px !important;
    gap: 2.56px;
  }

  .comparison-table--td-feature strong {
    font-size: 13.5px !important;
    color: #222;
    line-height: 19.58px !important;
