  </div>

  <div class="comparison-table--card-wrapper">
    <div class="comparison-table--badge">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M6.44708 0.301014C6.62379 -0.100338 7.1683 -0.100338 7.34502 0.301014L9.01208 4.08719C9.0841 4.25076 9.23208 4.36339 9.40284 4.3846L13.3553 4.87552C13.7743 4.92756 13.9425 5.47007 13.6328 5.77016L10.7106 8.60107C10.5844 8.72337 10.5279 8.90561 10.5614 9.08229L11.337 13.1719C11.4193 13.6054 10.9788 13.9407 10.6106 13.7248L7.13755 11.6882C6.9875 11.6002 6.8046 11.6002 6.65455 11.6882L3.1815 13.7248C2.81334 13.9407 2.37283 13.6054 2.45505 13.1719L3.23074 9.08229C3.26425 8.90561 3.20773 8.72337 3.08148 8.60107L0.159338 5.77016C-0.150423 5.47007 0.0178399 4.92756 0.436817 4.87552L4.38926 4.3846C4.56002 4.36339 4.70799 4.25076 4.78002 4.08719L6.44708 0.301014Z" fill="black"/>
      </svg>
      <span>Best Choice</span>
    </div>

    <div class="comparison-table--card">
    <table class="comparison-table">
      <thead>
        <tr>
          <th class="comparison-table--th-feature">What Matters</th>
          <th class="comparison-table--th-hero">
            <span class="comparison-table--col-name">Riehle's Select</span>
            <span class="comparison-table--col-sub">Hulless Popcorn</span>
          </th>
          <th class="comparison-table--th-comp">
            <span class="comparison-table--col-name">Orville Redenbacher</span>
            <span class="comparison-table--col-sub">Grocery Jar Kernels</span>
          </th>
          <th class="comparison-table--th-comp">
            <span class="comparison-table--col-name">Pop Secret</span>
            <span class="comparison-table--col-sub">Microwave Bags</span>
          </th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="comparison-table--td-feature">
            <strong>Nearly hull-free</strong>
            <small>Hull disintegrates during the pop</small>
          </td>
          <td class="comparison-table--td-hero">{% render 'icon-ct-yes' %}</td>
          <td>{% render 'icon-ct-no' %}</td>
          <td>{% render 'icon-ct-no' %}</td>
        </tr>
        <tr>
          <td class="comparison-table--td-feature">
            <strong>Tender — no digging in your teeth</strong>
          </td>
          <td class="comparison-table--td-hero">{% render 'icon-ct-yes' %}</td>
          <td>{% render 'icon-ct-no' %}</td>
          <td>{% render 'icon-ct-no' %}</td>
        </tr>
        <tr>
          <td class="comparison-table--td-feature">
            <strong>Easier on your stomach</strong>
          </td>
          <td class="comparison-table--td-hero">{% render 'icon-ct-yes' %}</td>
          <td>{% render 'icon-ct-no' %}</td>
          <td>{% render 'icon-ct-no' %}</td>
        </tr>
        <tr>
          <td class="comparison-table--td-feature">
            <strong>Grown, cleaned, sorted &amp; sealed on one farm</strong>
            <small>Full traceability — no middlemen</small>
          </td>
          <td class="comparison-table--td-hero">{% render 'icon-ct-yes' %}</td>
          <td>{% render 'icon-ct-no' %}</td>
          <td>{% render 'icon-ct-no' %}</td>
        </tr>
        <tr>
          <td class="comparison-table--td-feature">
            <strong>Family-owned — same Indiana farm since 1910</strong>
          </td>
          <td class="comparison-table--td-hero">{% render 'icon-ct-yes' %}</td>
          <td>{% render 'icon-ct-no' %}</td>
          <td>{% render 'icon-ct-no' %}</td>
        </tr>
        <tr>
          <td class="comparison-table--td-feature">
            <strong>One ingredient: popcorn</strong>
            <small>Nothing added, nothing hidden</small>
          </td>
          <td class="comparison-table--td-hero">{% render 'icon-ct-yes' %}</td>
          <td>{% render 'icon-ct-yes' %}</td>
          <td>{% render 'icon-ct-no' %}</td>
        </tr>
        <tr>
          <td class="comparison-table--td-feature">
            <strong>A real person answers the phone</strong>
          </td>
          <td class="comparison-table--td-hero">{% render 'icon-ct-yes' %}</td>
          <td>{% render 'icon-ct-no' %}</td>
          <td>{% render 'icon-ct-no' %}</td>
        </tr>
        <tr class="comparison-table--row-warning">
          <td class="comparison-table--td-feature comparison-table--td-warning">
            <em>Artificial "butter" flavoring with a diacetyl history</em>
          </td>
