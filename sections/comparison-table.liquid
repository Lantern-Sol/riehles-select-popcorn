<style>
  /* ── Theme reset: kill inherited font/spacing from theme.scss ── */
  .comparison-table--root,
  .comparison-table--root *,
  .comparison-table--root *::before,
  .comparison-table--root *::after {
    font-family: 'Roboto', sans-serif !important;
    margin: 0;
    box-sizing: border-box;
  }

  .comparison-table--root table {
    border: none !important;
    border-collapse: collapse !important;
    border-spacing: 0 !important;
    border-radius: 0 !important;
    background: #fff !important;
  }

  .comparison-table--root th,
  .comparison-table--root td {
    border-radius: 0 !important;
    margin: 0 !important;
    border: none;
  }

  .comparison-table--root tr {
    padding-bottom: 0 !important;
  }

  .comparison-table--root strong {
    font-weight: 500 !important;
  }

  .comparison-table--root h2 {
    font-family: 'Roboto', sans-serif !important;
    font-style: normal !important;
    text-transform: none !important;
  }

  /* ── Section root ── */
  .comparison-table--root {
    padding: 50px 100px 70px;
    background: #fff;
  }

  .comparison-table--header {
    text-align: center;
    margin-bottom: 30px;
  }

  .comparison-table--title {
    font-weight: 700 !important;
    font-size: 28px !important;
    line-height: 32px !important;
    color: #000;
    margin: 0 0 20px !important;
  }

  .comparison-table--subtitle {
    font-weight: 400 !important;
    font-size: 16px !important;
    color: #000;
    margin: 0 !important;
  }

  /* ── Card wrapper (holds badge outside overflow) ── */
  .comparison-table--card-wrapper {
    max-width: 860px;
    margin: 0 auto;
    position: relative;
  }

  /* ── Card container ── */
  .comparison-table--card {
    background: #fff;
    border-radius: 10px;
    box-shadow: 0 2px 24px rgba(0, 0, 0, 0.09);
    overflow: hidden;
  }

  /* ── Badge ── */
  .comparison-table--badge {
    position: absolute;
    top: -11px;
    left: 46.5%;
    transform: translateX(-50%);
    background: #ffd815;
    border-radius: 5.3px;
    padding: 3.8px 6.3px;
    display: inline-flex;
    align-items: center;
    gap: 3.8px;
    z-index: 2;
    font-weight: 700 !important;
    font-size: 13.7px !important;
    letter-spacing: -0.2px;
    color: #333;
    white-space: nowrap;
  }

  .comparison-table--badge svg {
