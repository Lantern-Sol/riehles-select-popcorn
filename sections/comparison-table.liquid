    border-left: 2px solid #007494 !important;
    border-right: 2px solid #007494 !important;
  }

  .comparison-table tbody td:not(.comparison-table--td-feature):not(.comparison-table--td-hero) {
    flex: 1;
  }

  /* ── SVG icons ── */
  .comparison-table tbody svg,
  .comparison-table--footer svg {
    display: block;
    flex-shrink: 0;
  }

  .comparison-table--icon-small {
    vertical-align: middle;
  }

  /* ── Footer ── */
  .comparison-table--footer {
    background: #333;
    border-top: 1px solid #e8e4de;
    padding: 12px 24px 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    font-size: 11px !important;
    color: #bbb;
    letter-spacing: 0.33px;
  }

  .comparison-table--legends {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .comparison-table--legend {
    display: inline-flex;
    align-items: center;
    gap: 3px;
  }

  .comparison-table--disclaimer {
    color: #bbb;
  }

  /* ── Dots (hidden on desktop) ── */
  .comparison-table--dots {
    display: none;
  }

  /* ── Mobile carousel ── */
  @media only screen and (max-width: 767px) {
    .comparison-table--root {
      padding: 40px 16px 50px;
    }

    .comparison-table--title {
      font-size: 22px !important;
      line-height: 28px !important;
    }

    .comparison-table--subtitle {
      font-size: 14px !important;
    }

    .comparison-table--card {
      overflow: hidden;
    }

    .comparison-table {
      min-width: 0 !important;
      width: 100% !important;
    }

    .comparison-table--badge {
      font-size: 11px !important;
      left: 79% !important;
      transition: opacity 0.8s ease;
    }

    .comparison-table--footer {
      min-width: 0;
      font-size: 10px !important;
      gap: 4px;
      flex-direction: column;
      align-items: center;
    }

    .comparison-table--legends {
      display: flex;
      gap: 10px;
    }

    .comparison-table--root td {
      margin: 0 !important;
    }

    /* ── 2-column layout: feature + one data col ── */
    .comparison-table thead tr,
    .comparison-table tbody tr {
      position: relative;
      overflow: hidden;
    }

    .comparison-table--th-feature {
      flex: 0 0 58% !important;
      padding: 24px 8px 14px 16px !important;
    }

    .comparison-table--td-feature {
      flex: 0 0 58% !important;
      padding: 12px 8px 12px 16px !important;
    }

    /* Hero column: in normal flow, provides height */
    .comparison-table--th-hero {
      flex: 0 0 42% !important;
      background: #007494 !important;
      min-height: 70px;
      padding: 10px 8px 2px !important;
      transition: opacity 0.8s ease;
    }

    .comparison-table--td-hero {
      flex: 0 0 42% !important;
      transition: opacity 0.8s ease;
    }

    /* Competitor columns: overlay the hero area */
    .comparison-table thead th:nth-child(3),
    .comparison-table thead th:nth-child(4) {
      position: absolute !important;
      right: 0;
      top: 0;
      width: 42%;
      height: 100%;
      opacity: 0;
      transition: opacity 0.8s ease;
      pointer-events: none;
      background: #333;
      flex: none !important;
      display: flex !important;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      padding: 10px 8px 14px !important;
    }

    .comparison-table tbody td:nth-child(3),
    .comparison-table tbody td:nth-child(4) {
      position: absolute !important;
      right: 0;
      top: 0;
      width: 42%;
      height: 100%;
      opacity: 0;
      transition: opacity 0.8s ease;
      pointer-events: none;
      flex: none !important;
      display: flex !important;
      align-items: center;
      justify-content: center;
    }

    /* Even row backgrounds for absolute cells */
    .comparison-table tbody tr:nth-child(even) td:nth-child(3),
    .comparison-table tbody tr:nth-child(even) td:nth-child(4) {
      background: #fafaf8;
    }

    .comparison-table tbody tr:nth-child(odd) td:nth-child(3),
    .comparison-table tbody tr:nth-child(odd) td:nth-child(4) {
      background: #fff;
    }

    .comparison-table--row-warning td:nth-child(3),
    .comparison-table--row-warning td:nth-child(4) {
      background: #fafaf8 !important;
    }

    /* ── Slide 0 (default): Riehle's Select ── */
    /* Hero is visible by default, comps hidden */

    /* ── Slide 1: Orville Redenbacher ── */
    .comparison-table[data-slide="1"] .comparison-table--th-hero,
    .comparison-table[data-slide="1"] .comparison-table--td-hero {
      opacity: 0;
      pointer-events: none;
    }
    .comparison-table[data-slide="1"] thead th:nth-child(3),
    .comparison-table[data-slide="1"] tbody td:nth-child(3) {
      opacity: 1;
      pointer-events: auto;
    }

    /* ── Slide 2: Orville / Pop Secret ── */
    .comparison-table[data-slide="2"] .comparison-table--th-hero,
    .comparison-table[data-slide="2"] .comparison-table--td-hero {
      opacity: 0;
      pointer-events: none;
    }
    .comparison-table[data-slide="2"] thead th:nth-child(4),
    .comparison-table[data-slide="2"] tbody td:nth-child(4) {
      opacity: 1;
      pointer-events: auto;
    }

    /* ── Remove hero highlight on mobile ── */
    .comparison-table--td-hero {
      background: transparent !important;
      border-left: none !important;
      border-right: none !important;
    }

    .comparison-table tbody tr:last-child .comparison-table--td-hero {
      border-bottom: none !important;
    }

    .comparison-table tbody tr:nth-child(even) .comparison-table--td-hero {
      background: transparent !important;
    }

    /* ── Pagination dots ── */
    .comparison-table--dots {
      display: flex;
      justify-content: center;
      gap: 8px;
      padding: 14px 0 4px;
    }

    .comparison-table--dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #ccc;
      border: none;
      padding: 0;
      cursor: pointer;
      transition: background 0.4s ease, transform 0.3s ease;
    }

    .comparison-table--dot.active {
      background: #007494;
      transform: scale(1.25);
    }
  }

  /* ── Tablet ── */
  @media only screen and (min-width: 768px) and (max-width: 1023px) {
    .comparison-table--root {
      padding: 50px 40px 60px;
    }
  }
</style>

<script>
(function() {
  var table = document.querySelector('.comparison-table');
  var dots = document.querySelectorAll('.comparison-table--dot');
  if (!table || !dots.length) return;

  var current = 0;
  var total = 3;
  var interval = 3000;
  var timer;

  var badge = document.querySelector('.comparison-table--badge');

  function goTo(index) {
    current = index;
    table.setAttribute('data-slide', current);
    dots.forEach(function(dot, i) {
      dot.classList.toggle('active', i === current);
    });
    if (badge && window.innerWidth < 768) {
      badge.style.opacity = current === 0 ? '1' : '0';
    }
  }

  function next() {
    goTo((current + 1) % total);
  }

  function startAuto() {
    stopAuto();
    timer = setInterval(next, interval);
  }

  function stopAuto() {
    if (timer) clearInterval(timer);
  }

  // Dot clicks
  dots.forEach(function(dot) {
    dot.addEventListener('click', function() {
      goTo(parseInt(this.getAttribute('data-slide')));
      startAuto();
    });
  });

  // Only auto-play on mobile
  var mq = window.matchMedia('(max-width: 767px)');
  function handleMQ(e) {
    if (e.matches) {
      goTo(0);
      startAuto();
    } else {
      stopAuto();
      table.removeAttribute('data-slide');
      if (badge) badge.style.opacity = '';
    }
  }
  mq.addListener(handleMQ);
  handleMQ(mq);
})();
</script>

