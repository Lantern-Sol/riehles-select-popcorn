    letter-spacing: 1.8px;
    text-transform: uppercase;
  }

  .comparison-table--th-hero {
    flex: 0 0 21%;
    background: #007494;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    padding: 12px 12px 2px !important;
    min-height: 86px;
  }

  .comparison-table--th-comp {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 3px;
    padding: 36.25px 12px 18px !important;
  }

  .comparison-table--col-name {
    font-weight: 700 !important;
    font-size: 14px !important;
    color: #fff;
    line-height: 17.5px !important;
  }

