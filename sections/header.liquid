{% capture general_settings %}{{ settings.color--alternative }}{% endcapture %}
<style>
  header .logo-image {
    max-height: {{ section.settings.logo-height }}px;
  }

  {% unless section.settings.logo %}
    body { background: #fff; }
    {% assign font--logo = settings.typography--logo %}
    {{ font--logo | font_face }}
  {% endunless %}
</style>

{% assign bg_color = section.settings.announcement--background-color %}
{% include 'framework--background-colors', bg_color: bg_color %}

<div
  class="header"
  {% if template contains 'index' and section.settings.transparent-menu %}
    data-header--menu-transparent="true"
  {% else %}
    data-header--menu-transparent="false"
  {% endif %}
  data-section-id="{{ section.id }}"
  data-section-type="header-section"
  data-js-class="Header"
>

  <div class="header--y-menu-for-off-canvas">
    {% include 'framework--y-menu', handle: section.settings.menu %}
  </div>

  {% include 'snippet-promo-bar' %}

  <header class="main-header">
    <div class="header--bg"></div>
    <div class="row top">
      {% if settings.show_multiple_currencies and section.settings.header-logo-center %}
        <div class="currency-selector columns left-aligned">
          {% include 'snippet-currency-selector' %}
        </div>
      {% endif %}

      <div class="columns{% if section.settings.header-logo-center %} logo-center{% endif %}">
        {% include 'snippet-store-title' %}
      </div>

      <div class="search-account columns">
        {% include 'snippet-searchbar-account' %}
      </div>

    </div><!-- .row -->

    <div class="bottom-row">
      <div class="row {% if section.settings.header-menu-center %} text-center{% endif %}">

      {% if linklists[section.settings.menu].links.size > 0 %}
        {% assign header_nav = section.settings.menu %}

        {% assign menu_alignment = 'left' %}
        {% if section.settings.header-menu-center %}
          {% assign menu_alignment = 'center' %}
        {% endif %}

        {%
          include 'framework--x-menu',
          js_class: 'XMenu',
          align: menu_alignment,
          handle: section.settings.menu
        %}

      {% endif %}

        <div class="columns cart-container">
          {% include 'snippet-cart', view: 'desktop' %}
        </div>
      </div>

    </div>

    <div class="header--mobile">
      <div class="off-canvas--open" data-off-canvas--open="left-sidebar">
        {% include 'snippet-symbol' with 'menu' %}
      </div>

      <div class="header--mobile--title">
        {% include 'snippet-store-title' %}
      </div>

      <div class="header--mobile--cart off-canvas--open font--accent"
          data-off-canvas--open="right-sidebar">
        {%- comment -%} Bold:POv2.3 HYBRID {%- endcomment -%}
        {% assign count = 0 %}
        {% for item in cart.items %}
          {% unless item.properties._boldBuilderId and item.properties._boldVariantIds == null %}
            {% capture temp %}{{ count | plus: item.quantity }}{% endcapture %}{% assign count = temp %}
          {% endunless %}
        {% endfor %}
        <span class="cart-icon-wrapper">
          <svg class="cart-icon-svg" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="3 5 18 16" fill="currentColor">
            <path d="M3.75 5.25C3.33691 5.25 3 5.58691 3 6C3 6.41309 3.33691 6.75 3.75 6.75H5.41406L7.38281 14.625C7.5498 15.293 8.14746 15.75 8.83594 15.75H17.4375C18.1143 15.75 18.6885 15.3018 18.8672 14.6484L20.8125 7.5H8.25L8.625 9H18.8672L17.4375 14.25H8.83594L6.86719 6.375C6.7002 5.70703 6.10254 5.25 5.41406 5.25H3.75ZM16.5 15.75C15.2666 15.75 14.25 16.7666 14.25 18C14.25 19.2334 15.2666 20.25 16.5 20.25C17.7334 20.25 18.75 19.2334 18.75 18C18.75 16.7666 17.7334 15.75 16.5 15.75ZM9.75 15.75C8.5166 15.75 7.5 16.7666 7.5 18C7.5 19.2334 8.5166 20.25 9.75 20.25C10.9834 20.25 12 19.2334 12 18C12 16.7666 10.9834 15.75 9.75 15.75ZM9.75 17.25C10.1719 17.25 10.5 17.5781 10.5 18C10.5 18.4219 10.1719 18.75 9.75 18.75C9.32812 18.75 9 18.4219 9 18C9 17.5781 9.32812 17.25 9.75 17.25ZM16.5 17.25C16.9219 17.25 17.25 17.5781 17.25 18C17.25 18.4219 16.9219 18.75 16.5 18.75C16.0781 18.75 15.75 18.4219 15.75 18C15.75 17.5781 16.0781 17.25 16.5 17.25Z" fill="currentColor"/>
          </svg>
          <span class="cart-icon-bubble number cart--external--total-items" data-item-count="{{ count }}">{{ count }}</span>
        </span>
      </div>

    </div>

    <div class="row">
      <div class="header-divider"></div>
    </div>
    
    <!-- Global site tag (gtag.js) - Google Ads: 1053022491 -->
<script async src="https://www.googletagmanager.com/gtag/js?id=AW-1053022491"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'AW-1053022491');
</script>

  </header>



</div>

{% schema %}
{
  "name": "Header",
  "class": "section--header",
  "settings": [
    {
      "type": "checkbox",
      "id": "transparent-menu",
      "label": "Transparent on home page",
      "info": "Only recommended when slideshow is first section"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "header-account-show",
      "label": "Enable customer account links",
      "default": true,
      "info": "[You will also need to enable customer accounts in your store settings](http:\/\/docs.shopify.com\/manual\/your-store\/customers\/customer-accounts)"
    },
    {
      "type": "checkbox",
      "id": "header-menu-center",
      "label": "Center align menu"
    },
    {
      "type": "header",
      "content": "Logo options"
    },
    {
      "type": "checkbox",
      "id": "header-logo-center",
      "label": "Center align"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Image",
      "info": "1600 x 200px max"
    },
    {
      "label": "Image Height",
      "id": "logo-height",
      "type": "range",
      "min": 15,
      "max": 100,
      "step": 5,
      "default": 50,
      "info": "This is referring to the natural height and should be half the height of the image you uploaded to ensure it stays sharp on retina screens."
    },
    {
      "type": "header",
      "content": "Announcement bar"
    },
    {
      "id": "announcement--background-color",
      "label": "Background color",
      "type": "select",
      "options": [
        { "label": "None", "value": "none" },
        { "label": "Light grey", "value": "light" },
        { "label": "Dark", "value": "dark" },
        { "label": "Accent", "value": "accent" }
      ],
      "default": "dark"
    },
    {
      "id": "announcement--alternative-color",
      "label": "Use alternative text color",
      "type": "checkbox",
      "default": true,
      "info": "This can found under theme settings below."
    },
    {
      "type": "select",
      "id": "header--promo-bar--show-on",
      "label": "Show on",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "all",
          "label": "All pages"
        },
        {
          "value": "home",
          "label": "Home page"
        }
      ]
    },
    {
      "type":  "text",
      "id":    "header--promo-bar--text",
      "label": "Text",
      "default": "Add your promotional message"
    },
    {
      "type":  "url",
      "id":    "header--promo-bar--link",
      "label": "Link",
      "info": "Optional"
    }
  ]
}
{% endschema %}